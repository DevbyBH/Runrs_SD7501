@model Runrs_SD7501.Models.User

@{
    ViewData["Title"] = "Registration";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Register</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #000000 30%, #ff770c 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            box-sizing: border-box;
        }

        .login-card {
            background: #D2D1D1;
            padding: 30px;
            width: 350px;
            border-radius: 12px;
            box-shadow: 0px 8px 25px rgba(0, 0, 0, 0.3);
            text-align: center;
            max-height: none;
            overflow-y: visible;
        }

        /* Center ALL logos */
        .logo {
            display: block;
            margin: 0 auto 10px auto;
            width: 140px;
        }

            /* Optional: make RunningMan slightly smaller */
            .logo.small {
                width: 110px;
            }

        h2 {
            margin-bottom: 15px;
        }

        .form-group {
            margin-bottom: 10px;
            text-align: left;
        }

        input {
            width: 100%;
            padding: 10px;
            border-radius: 6px;
            border: 1px solid #ccc;
            margin-top: 5px;
        }

        .btn {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 6px;
            margin-top: 10px;
            cursor: pointer;
            font-size: 16px;
        }

        .btn-create {
            background-color: #ff770c;
            color: white;
        }

            .btn-create:hover {
                background-color: #e0660b;
            }

        .btn-back {
            background-color: #444;
            color: white;
        }

            .btn-back:hover {
                background-color: #222;
            }

        .text-danger {
            font-size: 12px;
        }
    </style>
</head>

<body>

    <div class="login-card">

        <!-- RunningMan Logo -->
        <img src="@Url.Content("~/images/RunningMan.png")" class="logo small" />

        <h2>Register</h2>

        <form asp-controller="Login" asp-action="Registration" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Username"></label>
                <input asp-for="Username" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="FirstName"></label>
                <input asp-for="FirstName" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LastName"></label>
                <input asp-for="LastName" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PasswordHash"></label>
                <input asp-for="PasswordHash" type="password" />
                <span asp-validation-for="PasswordHash" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DateOfBirth"></label>
                <input asp-for="DateOfBirth" type="date" />
                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
            </div>

            <input type="submit" value="Create Account" class="btn btn-create" />
        </form>

        <form action="/Login/Index" method="get">
            <button type="submit" class="btn btn-back">Back to Login</button>
        </form>

    </div>

</body>
</html>