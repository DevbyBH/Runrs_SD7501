@model Runrs_SD7501.Models.User

@{
    ViewBag.Title = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Lugrasimo&display=swap" rel="stylesheet">
    <title>Login</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            /* Gradient background */
            background: linear-gradient(135deg, #000000 30%, #ff770c 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-card {
            background: #D2D1D1;
            padding: 40px;
            width: 350px;
            border-radius: 12px;
            box-shadow: 0px 8px 25px rgba(0, 0, 0, 0.3);
            text-align: center;
        }

        .login-card img {
            width: 180px;
            margin-bottom: 15px;
        }

        h2 {
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 15px;
            text-align: left;
            font-weight: bold;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 10px;
            border-radius: 6px;
            border: 1px solid #ccc;
            margin-top: 5px;
        }

        .btn {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 6px;
            margin-top: 10px;
            cursor: pointer;
            font-size: 16px;
        }

        .btn-login {
            background-color: #ff770c;
            color: white;
        }

        .btn-login:hover {
            background-color: #e0660b;
        }

        .btn-register {
            background-color: #444;
            color: white;
        }

        .btn-register:hover {
            background-color: #222;
        }

        .error-box {
            border: 1px solid red;
            padding: 10px;
            margin-bottom: 15px;
            color: red;
        }
    </style>
</head>

<body>

    <div class="login-card">

        <!-- Running image (make sure path + casing is correct) -->
        <img src="@Url.Content("~/images/RunningMan.png")" />

        <h2>Login</h2>

        @using (Html.BeginForm("Login", "Login", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true)

            if (ViewBag.Message != null)
            {
                <div class="error-box">
                    @ViewBag.Message
                </div>
            }

            <div class="form-group">
                @Html.LabelFor(a => a.Username):
                @Html.TextBoxFor(a => a.Username)
                @Html.ValidationMessageFor(a => a.Username)
            </div>

            <div class="form-group">
                @Html.LabelFor(a => a.PasswordHash):
                @Html.PasswordFor(a => a.PasswordHash)
                @Html.ValidationMessageFor(a => a.PasswordHash)
            </div>

            <input type="submit" value="Login" class="btn btn-login" />
        }

        <!-- Register button -->
        <form action="/Login/Registration" method="get">
            <button type="submit" class="btn btn-register">Create Account</button>
        </form>

    </div>

</body>
</html>